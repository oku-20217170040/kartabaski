# KAR-TA BASKI — Environment Variables
# Bu dosyayı kopyalayın: cp .env.local.example .env.local
# Tüm değerleri doldurun, ardından "npm run dev" çalıştırın.

# ── Site Genel ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME=KAR-TA BASKI
NEXT_PUBLIC_SITE_URL=https://kartabaski.com
NEXT_PUBLIC_PHONE=905050874726
NEXT_PUBLIC_PHONE_DISPLAY=0505 087 47 26

# ── Firebase (Client SDK — tarayıcıdan erişilir) ──────────────────────────────
# Firebase Console → Proje Ayarları → Genel → Web Uygulaması → SDK Yapılandırması
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Firebase Admin SDK (Sunucu tarafı — sadece server/API routes) ─────────────
# Firebase Console → Proje Ayarları → Hizmet Hesapları → Yeni Özel Anahtar Oluştur
# İndirilen JSON dosyasından:
#   projectId   → "project_id" alanı
#   clientEmail → "client_email" alanı
#   privateKey  → "private_key" alanı (tüm satır, başındaki/sonundaki tırnak dahil)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ── Cloudinary ────────────────────────────────────────────────────────────────
# cloudinary.com → Dashboard'dan alın
# Cloud Name: Settings → Account → Cloud Name
# API Key & Secret: Settings → API Keys
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Google Analytics (opsiyonel) ──────────────────────────────────────────────
# analytics.google.com → Yönetici → Veri Akışları → Web → Ölçüm Kimliği (G-XXXXXXX)
NEXT_PUBLIC_GA_ID=

# ── Sentry (opsiyonel — hata izleme) ─────────────────────────────────────────
# sentry.io → Settings → Projects → DSN
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
