rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Yardımcı fonksiyonlar ─────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── products koleksiyonu ──────────────────────────────────────────────────
    match /products/{productId} {
      // Admin paneli client SDK kullandığından tüm ürünleri okuyabilmeli
      allow read: if isAdmin();
      // Sadece admin yazabilir
      allow create, update, delete: if isAdmin();
      // NOT: Public site server-side Admin SDK ile okur (kural atlanır)
    }

    // ── users koleksiyonu ─────────────────────────────────────────────────────
    match /users/{userId} {
      // Kullanıcı kendi profilini okuyabilir
      allow read: if isSignedIn() && request.auth.uid == userId;
      // Admin tüm kullanıcıları yönetebilir
      allow read, write: if isAdmin();
    }

  }
}
